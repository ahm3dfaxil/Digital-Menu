rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user owns the restaurant
    function isOwner(restaurantId) {
      return request.auth != null && 
        (get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.ownerId == request.auth.uid);
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /restaurants/{restaurantId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.ownerId == request.auth.uid;
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow create: if request.auth != null && isOwner(request.resource.data.restaurantId);
      allow update, delete: if request.auth != null && isOwner(resource.data.restaurantId);
    }

    match /menuItems/{itemId} {
      allow read: if true;
      allow create: if request.auth != null && isOwner(request.resource.data.restaurantId);
      allow update, delete: if request.auth != null && isOwner(resource.data.restaurantId);
    }
  }
}
